{
  "name": "gitgym",
  "private": true,
  "packageManager": "pnpm@10.4.0",
  "scripts": {
    "dev": "node scripts/dev-orchestrator.mjs",
    "api:dev": "node scripts/run-with-env.mjs go run ./services/api/cmd/api",
    "runner:dev": "node scripts/run-with-env.mjs go run ./services/runner/cmd/runner",
    "db:migrate": "node scripts/run-with-env.mjs go run ./services/api/cmd/migrate",
    "test:dev": "node --test scripts/dev-orchestrator.test.mjs",
    "web:dev": "pnpm --dir apps/web dev",
    "web:test": "pnpm --dir apps/web test",
    "web:e2e": "pnpm --dir apps/web run test:e2e"
  }
}
